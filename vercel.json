{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/",
      "destination": "/home",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/home",
      "destination": "/index.html"
    },
    {
      "source": "/about",
      "destination": "/about/index.html"
    },
    {
      "source": "/work/orange-rockland",
      "destination": "/work/orange-rockland/index.html"
    },
    {
      "source": "/work/aca-group",
      "destination": "/work/aca-group/index.html"
    },
    {
      "source": "/work/national-grid",
      "destination": "/work/national-grid/index.html"
    }
  ]
}
